{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/v2/core/tauri-config-schema/schema.json",
  "productName": "Aura Alpha",
  "identifier": "cc.auraalpha.desktop",
  "version": "1.1.7",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Aura Alpha",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true,
        "decorations": true,
        "resizable": true,
        "fullscreen": false,
        "transparent": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "tooltip": "Aura Alpha"
    },
    "security": {}

  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Aura Alpha",
    "copyright": "2026 Aura Alpha",
    "category": "Finance",
    "shortDescription": "Algorithmic Trading Desk",
    "longDescription": "Aura Alpha is a multi-bot, risk-siloed algorithmic trading platform with real-time monitoring, strategy management, and advanced analytics.",
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installMode": "both"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libayatana-appindicator3-1"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMxRjg0QTM5NjA0OUI1OTIKUldTU3RVbGdPVXI0TWRWNWxJVUdGSW1zdjladGYrV2RXeUpVNCtSaktRNEVDa2o2dmRsZWVCRnEK",
      "endpoints": [
        "https://auraalpha.cc/api/desktop/update/{{target}}/{{arch}}/{{current_version}}"
      ],
      "dialog": true
    }
  }
}
